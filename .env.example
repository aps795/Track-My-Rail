# Track My Rail - Environment Configuration
# =====================================================
# Copy this file to .env and fill in your API keys
# DO NOT commit .env to git (already in .gitignore)
# =====================================================

# Backend Server Port
PORT=5000

# =====================================================
# CHOOSE ONE API SOURCE (or leave all blank for MOCK_DATA)
# =====================================================

# Option 1: RapidAPI Third-Party (FASTEST - Try This First!)
# ─────────────────────────────────────────────────────────
# Setup: 5 minutes
# Cost: Free tier available
# Accuracy: 95%
# 
# Get it: 
# 1. Go to https://rapidapi.com/
# 2. Sign up (free)
# 3. Search: "Indian Railway API"
# 4. Subscribe to free tier
# 5. Copy "X-RapidAPI-Key" from Dashboard
#
# Example:
RAPID_API_KEY=your_rapidapi_key_here_1234567890
RAPID_API_HOST=indian-railway-api.p.rapidapi.com

# ─────────────────────────────────────────────────────────

# Option 2: Official IRCTC API (BEST for Production)
# ─────────────────────────────────────────────────────────
# Setup: 2-3 days (requires approval)
# Cost: Free/Paid plans
# Accuracy: 100% (Official data)
#
# Get it:
# 1. Go to https://www.irctc.co.in/nget/in/developer-resources
# 2. Fill registration form
# 3. Wait for approval
# 4. Get API Key + Secret
# 5. Add below:
#
# Example:
IRCTC_API_KEY=your_irctc_api_key_here
IRCTC_API_SECRET=your_irctc_api_secret_here

# ─────────────────────────────────────────────────────────

# Option 3: No API - Use MOCK DATA (DEFAULT)
# ─────────────────────────────────────────────────────────
# Setup: Already done!
# Cost: Free
# Perfect for: Development & testing
# 
# Leave all API keys above blank/commented to use MOCK_DATA
# (This is the default if no keys are provided)

# =====================================================
# Optional Configuration
# =====================================================

# Node Environment (development / production)
NODE_ENV=development

# JWT Configuration (for authentication features)
JWT_SECRET=your_secret_key_change_this_in_production

# Database Configuration (for future use)
DB_HOST=localhost
DB_PORT=27017
DB_NAME=track_my_rail
DB_USER=
DB_PASSWORD=

# =====================================================
# IMPORTANT SETUP INSTRUCTIONS
# =====================================================
#
# 1. First Time Setup (Development):
#    → Leave all API keys blank
#    → Backend will auto-use MOCK_DATA
#    → Great for testing UI/UX
#
# 2. Testing with Real Data (Quick):
#    → Get RapidAPI key (5 min from https://rapidapi.com/)
#    → Add RAPID_API_KEY above
#    → Restart: npm start
#    → Test API response shows "dataSource": "RAPID_API"
#
# 3. Production (Best):
#    → Apply for IRCTC Official API
#    → Get credentials
#    → Add IRCTC_API_KEY + IRCTC_API_SECRET
#    → Restart: npm start
#    → Test response shows "dataSource": "IRCTC_OFFICIAL"
#
# =====================================================
# HOW IT WORKS (Auto-Detection)
# =====================================================
#
# Backend automatically detects which to use:
#
# Priority Order:
# 1. IRCTC_API_KEY set? → Use IRCTC Official API (Best accuracy)
# 2. RAPID_API_KEY set? → Use RapidAPI (Good for testing)
# 3. Neither set? → Use Built-in MOCK_DATA (No internet needed)
#
# No code changes needed! Just set the API keys.
#
# =====================================================

